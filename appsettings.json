{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "YOUR_DB_CONNECTION_STRING",
    "Redis": "YOUR_REDIS_CONNECTION_STRING",
    "RabbitMq": "YOUR_RABBITMQ_CONNECTION_STRING"
  },
  "JwtSettings": {
    "SecretKey": "YOUR_JWT_SECRET_KEY",
    "Issuer": "ISSUER_URL",
    "Audience": "AUDIENCE_URL",
    "ExpiryMinutes": 60
  },
  "FileStorageSettings": {
    "StorageRootPath": "FILE_PATH",
    "MaxSizeMb": "2",
    "AllowedExtension": [
      ".docx",
      ".doc",
      ".pdf",
      ".txt"
    ]
  },
  "RabbitMqSettings": {
    "Uri": "YOUR_RABBITMQ_CONNECTION_STRING"
  }
}
